{
  "harness": "pi",
  "version": "0.2.0",
  "capabilities": [
    "primary_control",
    "specialist_routing",
    "lazy_skills",
    "permission_enforcement",
    "trace_emission",
    "eval_execution",
    "model_assignment",
    "local_first"
  ],
  "agent_files": [
    "orchestrator.md",
    "developer.md",
    "qa.md",
    "librarian.md",
    "architect.md",
    "reviewer.md"
  ],
  "skills": {
    "registry": "skills/registry.json",
    "policy": {
      "loading": "lazy",
      "default": "available",
      "scope": "task-specific",
      "load_bodies_globally": false
    }
  },
  "pi_adapter": {
    "runtime": "pi-adapter/runtime.js",
    "cli": "pi-adapter/cli.js"
  }
}