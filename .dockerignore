# Release docs (keep build small)
.ai/releases
.ai/observability

# v0.4.1 deployment docs are not needed in the image
# BUT the openapi-router reads two specific files at runtime for
# /agents/manifest and /skills/manifest. They're tiny and have no secrets.
# We exclude .ai/ broadly, then re-include those two files.
.ai
!.ai/agents/registry.json
!.ai/skills/registry.json

# Roadmap drafts
**/*.draft.md
**/*.draft.json
