# Alfred Memory E2E environment configuration.
# Copy this file to packages/memory-e2e/.env and fill the real values.
# Never commit .env with secrets.

# PostgreSQL
POSTGRES_USER=alfred
POSTGRES_PASSWORD=change_me_in_env_file
POSTGRES_DB=alfred_memory
DATABASE_URL=postgres://alfred:change_me_in_env_file@localhost:5432/alfred_memory

# Memory API server
MEMORY_API_PORT=8080
MEMORY_API_KEYS={"local-test-key":"user_001"}

# Public HTTPS tunnel (choose one)
# Cloudflare Tunnel: set CF_TUNNEL_TOKEN if you already have a named tunnel.
CF_TUNNEL_TOKEN=
CF_TUNNEL_HOSTNAME=https://memory.example.com

# ngrok: set NGROK_AUTHTOKEN and optionally NGROK_DOMAIN.
NGROK_AUTHTOKEN=
NGROK_DOMAIN=

# Custom GPT Action (used in manual checklist only)
CUSTOM_GPT_NAME="Alfred Memory (dev)"
