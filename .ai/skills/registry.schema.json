{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Alfred Skill Registry",
  "type": "object",
  "required": ["skills"],
  "properties": {
    "version": { "type": "string" },
    "policy": {
      "type": "object",
      "required": ["loading", "default", "scope", "activation", "load_bodies_globally"],
      "properties": {
        "loading": { "const": "lazy" },
        "default": { "const": "do-not-load" },
        "scope": { "type": "string" },
        "activation": { "type": "string" },
        "load_bodies_globally": { "const": false }
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "triggers", "projectSignals", "source", "scope", "bodyPath", "allowedAgents", "loadsBodyByDefault"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "triggers": { "type": "array", "items": { "type": "string" } },
          "projectSignals": { "type": "array", "items": { "type": "string" } },
          "source": { "type": "string" },
          "scope": { "const": "project" },
          "bodyPath": { "type": "string" },
          "allowedAgents": { "type": "array", "items": { "type": "string" } },
          "loadsBodyByDefault": { "const": false }
        }
      }
    }
  }
}
