{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Alfred Skill Registry",
  "type": "object",
  "required": ["skills"],
  "properties": {
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "triggers", "source"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "triggers": { "type": "array", "items": { "type": "string" } },
          "projectSignals": { "type": "array", "items": { "type": "string" } },
          "source": { "type": "string" },
          "allowedAgents": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
