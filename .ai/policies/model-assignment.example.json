{
  "ownership": {
    "agent_specs_may_pin_models": false,
    "assignment_owner": "user"
  },
  "models": {
    "*": {
      "primary": "ollama/qwen2.5-coder:7b",
      "fallbacks": ["openai/gpt-4.1-mini", "anthropic/claude-sonnet-4"]
    },
    "orchestrator": {
      "primary": "anthropic/claude-sonnet-4",
      "fallbacks": ["openai/gpt-4.1-mini"]
    },
    "developer": {
      "primary": "anthropic/claude-sonnet-4",
      "fallbacks": ["openai/gpt-4.1-mini", "ollama/qwen2.5-coder:7b"]
    },
    "qa": {
      "fallbacks": ["openai/gpt-4.1-mini"]
    },
    "librarian": {
      "primary": "openai/gpt-4.1-mini",
      "fallbacks": []
    },
    "architect": {
      "primary": "anthropic/claude-sonnet-4",
      "fallbacks": ["openai/gpt-4.1-mini"]
    },
    "reviewer": {
      "primary": "openai/gpt-4.1-mini",
      "fallbacks": ["ollama/qwen2.5-coder:7b"]
    },
    "temporary": {
      "fallbacks": ["openai/gpt-4.1-mini"]
    },
    "temporary:*": {
      "primary": "openai/gpt-4.1-mini"
    },
    "fallbacks": ["ollama/qwen2.5-coder:7b", "openai/gpt-4.1-mini", "anthropic/claude-sonnet-4"]
  },
  "installer": {
    "target_path": "~/.alfred/models.json",
    "preview_first": true,
    "atomic_writes": true,
    "live_harness_config_writes": false,
    "trace_events": ["model_assignment_configured", "provider_request_avoided"],
    "provider_calls_allowed": 0
  },
  "fallback": {
    "retries_before_switch": 3,
    "switch_on": [
      "provider_timeout",
      "provider_rate_limit",
      "provider_unavailable",
      "model_context_limit_exceeded",
      "recoverable_provider_error"
    ],
    "on_all_models_failed": "explain_failure_to_user"
  }
}
