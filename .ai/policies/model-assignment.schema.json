{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Alfred Model Assignment Policy",
  "type": "object",
  "required": ["ownership", "models", "fallback", "installer"],
  "properties": {
    "ownership": {
      "type": "object",
      "required": ["agent_specs_may_pin_models", "assignment_owner"],
      "properties": {
        "agent_specs_may_pin_models": { "const": false },
        "assignment_owner": { "const": "user" }
      },
      "additionalProperties": false
    },
    "models": {
      "type": "object",
      "properties": {
        "fallbacks": { "type": "array", "items": { "$ref": "#/$defs/modelId" } }
      },
      "patternProperties": {
        "^(\\*|[A-Za-z0-9_-]+|temporary(?::[A-Za-z0-9_*.-]+)?)$": { "$ref": "#/$defs/modelEntry" }
      },
      "additionalProperties": false
    },
    "installer": {
      "type": "object",
      "required": ["target_path", "preview_first", "atomic_writes", "live_harness_config_writes", "provider_calls_allowed"],
      "properties": {
        "target_path": { "const": "~/.alfred/models.json" },
        "preview_first": { "const": true },
        "atomic_writes": { "const": true },
        "live_harness_config_writes": { "const": false },
        "trace_events": {
          "type": "array",
          "items": { "enum": ["model_assignment_configured", "model_assignment_resolved", "provider_request_avoided"] }
        },
        "provider_calls_allowed": { "const": 0 }
      },
      "additionalProperties": false
    },
    "fallback": {
      "type": "object",
      "required": ["retries_before_switch", "on_all_models_failed"],
      "properties": {
        "retries_before_switch": { "type": "integer", "minimum": 1, "maximum": 10 },
        "switch_on": { "type": "array", "items": { "type": "string" } },
        "on_all_models_failed": { "const": "explain_failure_to_user" }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "modelId": { "type": "string", "minLength": 1 },
    "modelEntry": {
      "type": "object",
      "properties": {
        "primary": { "$ref": "#/$defs/modelId" },
        "fallbacks": { "type": "array", "items": { "$ref": "#/$defs/modelId" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
